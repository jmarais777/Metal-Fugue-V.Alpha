:root {
}

.header {
    justify-content: flex-start;
    align-self: center;
    width: 220px;
    height: 60px;
}

.Button {
    width: 220px;
    height: 60px;
    align-self: center;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    border-bottom-left-radius: 10px;
    font-size: 16px;
}

.button:hover {
    font-size: 20px;
}
